local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local HttpService = game:GetService("HttpService")
local LocalPlayer = Players.LocalPlayer

-- ── Helpers ──────────────────────────────────────────────
local function mk(className, props, parent)
    local inst = Instance.new(className)
    for prop, value in pairs(props or {}) do
        pcall(function() inst[prop] = value end)
    end
    if parent then inst.Parent = parent end
    return inst
end

local function corner(radius, parent)
    return mk("UICorner", { CornerRadius = UDim.new(0, tonumber(radius) or 0) }, parent)
end

local function padding(top, bottom, left, right, parent)
    return mk("UIPadding", {
        PaddingTop = UDim.new(0, top),
        PaddingBottom = UDim.new(0, bottom),
        PaddingLeft = UDim.new(0, left),
        PaddingRight = UDim.new(0, right),
    }, parent)
end

local function stroke(color, thickness, transparency, parent)
    return mk("UIStroke", {
        Color = color,
        Thickness = thickness or 1,
        Transparency = transparency or 0,
    }, parent)
end

local function tween(inst, duration, props, style, dir)
    local info = TweenInfo.new(duration, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out)
    local t = TweenService:Create(inst, info, props)
    t:Play()
    return t
end

-- Spring-based tween for more fluid feel
local function spring(inst, duration, props)
    local info = TweenInfo.new(duration, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out, 0, false, 0)
    local t = TweenService:Create(inst, info, props)
    t:Play()
    return t
end

-- Smooth exponential tween
local function smooth(inst, duration, props)
    local info = TweenInfo.new(duration, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
    local t = TweenService:Create(inst, info, props)
    t:Play()
    return t
end

local function getHost()
    local host
    pcall(function()
        host = gethui and gethui() or game:GetService("CoreGui")
    end)
    host = host or LocalPlayer:WaitForChild("PlayerGui")
    return host
end

local function lerpColor(a, b, t)
    return Color3.new(
        a.R + (b.R - a.R) * t,
        a.G + (b.G - a.G) * t,
        a.B + (b.B - a.B) * t
    )
end

-- ── Panel ────────────────────────────────────────────────
local Panel = {}
Panel.__index = Panel

function Panel:_init(ui, title, width)
    self._ui = ui
    self._theme = ui._theme

    local theme = self._theme
    local x, y = ui:_nextPanelPos(width)

    local frame = mk("Frame", {
        Position = UDim2.fromOffset(x, y - 30),
        Size = UDim2.new(0, width, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = theme.panel,
        BackgroundTransparency = theme.panelTrans + 0.15,
        ZIndex = 100010,
    }, ui._root)
    corner(8, frame)
    stroke(theme.border, 1, theme.strokeTrans, frame)

    -- Glass effect overlay
    local glass = mk("Frame", {
        Size = UDim2.fromScale(1, 1),
        BackgroundColor3 = theme.white,
        BackgroundTransparency = 0.92,
        BorderSizePixel = 0,
        ZIndex = 100009,
    }, frame)
    corner(8, glass)

    mk("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder }, frame)

    local header = mk("Frame", {
        Size = UDim2.new(1, 0, 0, 30),
        BackgroundColor3 = theme.header,
        BackgroundTransparency = 0.1,
        LayoutOrder = 1,
        ZIndex = 100011,
    }, frame)
    corner(8, header)
    mk("Frame", {
        Size = UDim2.new(1, 0, 0, 12),
        Position = UDim2.new(0, 0, 1, -12),
        BackgroundColor3 = theme.header,
        BackgroundTransparency = 0.1,
        BorderSizePixel = 0,
        ZIndex = 100010,
    }, header)

    -- Animated accent dot
    local dot = mk("Frame", {
        Size = UDim2.fromOffset(9, 9),
        Position = UDim2.new(0, 10, 0.5, -4),
        BackgroundColor3 = theme.accent,
        ZIndex = 100012,
    }, header)
    corner(5, dot)

    -- Pulse animation on dot
    spawn(function()
        while dot.Parent do
            tween(dot, 1.2, { Size = UDim2.fromOffset(11, 11) }, Enum.EasingStyle.Sine)
            task.wait(1.2)
            tween(dot, 1.2, { Size = UDim2.fromOffset(9, 9) }, Enum.EasingStyle.Sine)
            task.wait(1.2)
        end
    end)

    local titleLabel = mk("TextLabel", {
        Text = (ui._title and ui._title .. ": " or "") .. title,
        Font = Enum.Font.GothamMedium,
        TextSize = 12,
        TextColor3 = theme.text,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -60, 1, 0),
        Position = UDim2.new(0, 26, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 100012,
    }, header)

    local collapse = mk("TextButton", {
        Text = "–",
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        TextColor3 = theme.muted,
        BackgroundTransparency = 1,
        AutoButtonColor = false,
        Size = UDim2.new(0, 26, 1, 0),
        Position = UDim2.new(1, -28, 0, 0),
        ZIndex = 100012,
    }, header)

    local body = mk("Frame", {
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        LayoutOrder = 2,
        ZIndex = 100011,
    }, frame)
    mk("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 3),
    }, body)
    padding(6, 8, 8, 8, body)

    local open = true
    collapse.MouseButton1Click:Connect(function()
        open = not open
        body.Visible = open
        collapse.Text = open and "–" or "+"
        if open then
            smooth(body, 0.25, { BackgroundTransparency = 1 })
        end
    end)
    collapse.MouseEnter:Connect(function() tween(collapse, 0.15, { TextColor3 = theme.accent }) end)
    collapse.MouseLeave:Connect(function() tween(collapse, 0.15, { TextColor3 = theme.muted }) end)

    ui:_makeDraggable(header, frame)

    self._frame = frame
    self._body = body
    self._header = header
    self._titleLabel = titleLabel
    self._open = true
    self._dot = dot
    self._glass = glass

    -- Glassmorphism fluid load-in animation
    frame.BackgroundTransparency = 1
    frame.Size = UDim2.new(0, width, 0, 0)
    smooth(frame, 0.35, { Position = UDim2.fromOffset(x, y), BackgroundTransparency = theme.panelTrans + 0.15 })

    return self
end

function Panel:SetTitle(title)
    self._titleLabel.Text = (self._ui._title and self._ui._title .. ": " or "") .. title
end

function Panel:SetVisible(visible)
    local theme = self._theme
    if visible then
        self._frame.Visible = true
        smooth(self._frame, 0.25, { BackgroundTransparency = theme.panelTrans + 0.15 })
    else
        smooth(self._frame, 0.2, { BackgroundTransparency = 1 })
        task.delay(0.22, function()
            if self._frame then self._frame.Visible = false end
        end)
    end
end

function Panel:SetOrder(order)
    self._frame.LayoutOrder = order
end

function Panel:_row(height)
    local theme = self._theme
    local row = mk("Frame", {
        Size = UDim2.new(1, 0, 0, height),
        BackgroundColor3 = theme.row,
        BackgroundTransparency = 1,
        ZIndex = 100012,
    }, self._body)
    corner(5, row)
    row.MouseEnter:Connect(function() tween(row, 0.12, { BackgroundTransparency = 0.55 }) end)
    row.MouseLeave:Connect(function() tween(row, 0.15, { BackgroundTransparency = 1 }) end)
    return row
end

function Panel:AddLabel(text)
    local theme = self._theme
    local w = { type = "label", value = text }
    mk("TextLabel", {
        Text = text,
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextColor3 = theme.muted,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 16),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 100013,
    }, self._body)
    self._ui:_registerWidget(w)
    return w
end

