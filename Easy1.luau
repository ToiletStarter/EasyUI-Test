    }, row)

    local track = mk("Frame", {
        Size = UDim2.new(1, 0, 0, 22),
        Position = UDim2.new(0, 0, 0, 16),
        BackgroundColor3 = theme.rowAlt,
        BorderSizePixel = 0,
        ZIndex = 100013,
    }, row)
    corner(11, track)

    local segmentWidth = 1 / #modes

    -- Segment dividers
    for i = 2, #modes do
        mk("Frame", {
            Size = UDim2.new(0, 1, 0, 14),
            Position = UDim2.new((i - 1) * segmentWidth, 0, 0, 4),
            BackgroundColor3 = theme.border,
            BorderSizePixel = 0,
            ZIndex = 100015,
        }, track)
    end

    local fill = mk("Frame", {
        Size = UDim2.fromScale(segmentWidth, 1),
        Position = UDim2.fromScale((defaultIndex - 1) * segmentWidth, 0),
        BackgroundColor3 = theme.accent,
        BackgroundTransparency = 0.2,
        BorderSizePixel = 0,
        ZIndex = 100014,
    }, track)
    corner(11, fill)

    -- Mode labels
    local modeLabels = {}
    for i, modeName in ipairs(modes) do
        local lbl = mk("TextLabel", {
            Text = modeName,
            Font = Enum.Font.GothamMedium,
            TextSize = 9,
            TextColor3 = i == defaultIndex and theme.text or theme.dim,
            BackgroundTransparency = 1,
            Size = UDim2.fromScale(segmentWidth, 1),
            Position = UDim2.fromScale((i - 1) * segmentWidth, 0),
            ZIndex = 100016,
        }, track)
        modeLabels[i] = lbl
    end

    local widget = { type = "modetoggle", value = defaultIndex, _modes = modes }

    local function snapToIndex(idx)
        idx = math.clamp(idx, 1, #modes)
        widget.value = idx
        tween(fill, 0.2, {
            Size = UDim2.fromScale(segmentWidth, 1),
            Position = UDim2.fromScale((idx - 1) * segmentWidth, 0),
        }, Enum.EasingStyle.Back)

        for i, lbl in ipairs(modeLabels) do
            tween(lbl, 0.15, { TextColor3 = i == idx and theme.text or theme.dim })
        end

        if callback then callback(idx, modes[idx]) end
    end

    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            local relX = (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
            local idx = math.floor(relX * #modes) + 1
            snapToIndex(idx)
        end
    end)

    function widget:Set(idx) snapToIndex(idx) end
    function widget:Get() return widget.value end
    function widget:GetMode() return modes[widget.value] end

    self._ui:_registerWidget(widget)
    return widget
end

function Panel:AddDropdown(label, options, default, callback)
    local theme = self._theme

    local wrapper = mk("Frame", {
        Size = UDim2.new(1, 0, 0, 24),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        ZIndex = 100014,
    }, self._body)
    mk("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 2) }, wrapper)

    local row = mk("Frame", {
        Size = UDim2.new(1, 0, 0, 24),
        BackgroundTransparency = 1,
        LayoutOrder = 1,
        ZIndex = 100014,
    }, wrapper)
    padding(0, 0, 8, 6, row)

    mk("TextLabel", {
        Text = label,
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextColor3 = theme.text,
        BackgroundTransparency = 1,
        Size = UDim2.new(0.5, 0, 1, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 100015,
    }, row)

    local button = mk("TextButton", {
        Text = "",
        Size = UDim2.new(0, 96, 0, 18),
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, 0, 0.5, 0),
        BackgroundColor3 = theme.rowAlt,
        AutoButtonColor = false,
        ZIndex = 100015,
    }, row)
    corner(4, button)
    stroke(theme.border, 1, 0.2, button)

    local valueText = mk("TextLabel", {
        Text = default,
        Font = Enum.Font.Gotham,
        TextSize = 10,
        TextColor3 = theme.text,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -16, 1, 0),
        Position = UDim2.new(0, 6, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 100016,
    }, button)

    local arrow = mk("TextLabel", {
        Text = "▾",
        Font = Enum.Font.Gotham,
        TextSize = 9,
        TextColor3 = theme.dim,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 12, 1, 0),
        Position = UDim2.new(1, -12, 0, 0),
        ZIndex = 100016,
    }, button)

    local list = mk("Frame", {
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundColor3 = theme.header,
        ClipsDescendants = true,
        LayoutOrder = 2,
        ZIndex = 100016,
    }, wrapper)
    corner(5, list)
    stroke(theme.border, 1, 0.2, list)
    mk("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder }, list)
    padding(3, 3, 3, 3, list)

    local selected = default
    local open = false
    local optionButtons = {}
    local widget = { type = "dropdown", value = default, _options = options }

    local function rebuildOptions()
        for _, b in ipairs(optionButtons) do pcall(function() b:Destroy() end) end
        optionButtons = {}
        for _, option in ipairs(options) do
            local optionButton = mk("TextButton", {
                Text = option,
                Font = Enum.Font.Gotham,
                TextSize = 10,
                TextColor3 = option == selected and theme.accent or theme.muted,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 18),
                AutoButtonColor = false,
                ZIndex = 100017,
            }, list)
            corner(3, optionButton)
            optionButton.MouseEnter:Connect(function()
                tween(optionButton, 0.1, { BackgroundTransparency = 0.7, BackgroundColor3 = theme.accentDim })
            end)
            optionButton.MouseLeave:Connect(function()
                tween(optionButton, 0.1, { BackgroundTransparency = 1 })
            end)
            optionButton.MouseButton1Click:Connect(function()
                selected = option
                widget.value = option
                valueText.Text = option
                if callback then callback(option) end
                open = false
                tween(list, 0.16, { Size = UDim2.new(1, 0, 0, 0) }, Enum.EasingStyle.Quint)
                tween(arrow, 0.15, { Rotation = 0 })
                for _, b2 in ipairs(optionButtons) do
                    tween(b2, 0.15, { TextColor3 = (b2.Text == option) and theme.accent or theme.muted })
                end
            end)
            optionButtons[#optionButtons + 1] = optionButton
        end
    end

    button.MouseButton1Click:Connect(function()
        open = not open
        tween(list, 0.18, {
            Size = open and UDim2.new(1, 0, 0, #options * 18 + 6) or UDim2.new(1, 0, 0, 0)
        }, Enum.EasingStyle.Quint)
        tween(arrow, 0.15, { Rotation = open and 180 or 0 })
    end)

    function widget:Set(value)
        selected = value
        widget.value = value
        valueText.Text = value
        for _, b2 in ipairs(optionButtons) do
            tween(b2, 0.15, { TextColor3 = (b2.Text == value) and theme.accent or theme.muted })
        end
        if callback then callback(value) end
    end
    function widget:Get() return selected end
    function widget:SetOptions(newOptions)
        options = newOptions
        widget._options = newOptions
        rebuildOptions()
    end

    rebuildOptions()
    self._ui:_registerWidget(widget)
    return widget
end

function Panel:AddButton(label, callback, danger)
    local theme = self._theme
    local color = danger and theme.bad or theme.accent

    local button = mk("TextButton", {
        Text = label,
        Font = Enum.Font.GothamMedium,
        TextSize = 11,
        TextColor3 = theme.text,
        BackgroundColor3 = theme.row,
        BackgroundTransparency = 0.3,
        AutoButtonColor = false,
        Size = UDim2.new(1, 0, 0, 25),
        ZIndex = 100013,
    }, self._body)
    corner(5, button)
    stroke(theme.border, 1, 0.2, button)

    button.MouseEnter:Connect(function()
        tween(button, 0.12, { BackgroundTransparency = 0, TextColor3 = color })
        local s = button:FindFirstChildOfClass("UIStroke")
        if s then tween(s, 0.12, { Color = color }) end
    end)
    button.MouseLeave:Connect(function()
        tween(button, 0.15, { BackgroundTransparency = 0.3, TextColor3 = theme.text })
        local s = button:FindFirstChildOfClass("UIStroke")
        if s then tween(s, 0.15, { Color = theme.border }) end
    end)
    button.MouseButton1Click:Connect(function()
        -- Click animation
        tween(button, 0.05, { Size = UDim2.new(0.97, 0, 0, 23) })
        task.wait(0.05)
        tween(button, 0.1, { Size = UDim2.new(1, 0, 0, 25) }, Enum.EasingStyle.Back)
        if callback then callback() end
    end)

    local widget = { type = "button" }
    function widget:Fire() if callback then callback() end end
    self._ui:_registerWidget(widget)
    return widget
end

-- ── Improved Color Picker with dotted crosshair ─────────
function Panel:AddColorPicker(label, defaultColor, callback)
    local theme = self._theme
    defaultColor = defaultColor or theme.white

    local row = self:_row(24)
    padding(0, 0, 8, 6, row)

    mk("TextLabel", {
        Text = label,
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextColor3 = theme.text,
        BackgroundTransparency = 1,
        Size = UDim2.new(0.4, 0, 1, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 100013,
    }, row)

    local swatch = mk("TextButton", {
        Text = "",
        Size = UDim2.fromOffset(26, 15),
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, 0, 0.5, 0),
        BackgroundColor3 = defaultColor,
        AutoButtonColor = false,
        ZIndex = 100013,
    }, row)
    corner(3, swatch)
    stroke(theme.borderBright, 1, 0, swatch)

    local hexBox = mk("TextBox", {
        Text = string.format("#%02X%02X%02X", math.floor(defaultColor.R * 255), math.floor(defaultColor.G * 255), math.floor(defaultColor.B * 255)),
        Font = Enum.Font.Code,
        TextSize = 9,
        TextColor3 = theme.muted,
        BackgroundColor3 = theme.rowAlt,
        ClearTextOnFocus = false,
        Size = UDim2.fromOffset(58, 15),
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -32, 0.5, 0),
        TextXAlignment = Enum.TextXAlignment.Center,
        ZIndex = 100013,
    }, row)
    corner(3, hexBox)

    -- Picker popup
    local picker = mk("Frame", {
        Size = UDim2.fromOffset(160, 116),
        Position = UDim2.new(1, 10, 0, 0),
        BackgroundColor3 = theme.header,
        BackgroundTransparency = 0.05,
        Visible = false,
        ZIndex = 100050,
    }, row)
    corner(6, picker)
    stroke(theme.border, 1, 0.15, picker)
    padding(8, 8, 8, 8, picker)

    local hue, sat, val = 0, 0.65, 1
    local widget = { type = "color", value = defaultColor }

    local function setColor(color)
        swatch.BackgroundColor3 = color
        hexBox.Text = string.format("#%02X%02X%02X", math.floor(color.R * 255), math.floor(color.G * 255), math.floor(color.B * 255))
        widget.value = color
        if callback then callback(color) end
    end

    -- SV Grid
    local grid = mk("Frame", {
        Size = UDim2.fromOffset(144, 62),
        BackgroundColor3 = Color3.fromHSV(hue, 1, 1),
        BorderSizePixel = 0,
        ZIndex = 100051,
    }, picker)
    corner(4, grid)

    mk("UIGradient", {
        Color = ColorSequence.new(Color3.new(1, 1, 1), Color3.fromHSV(hue, 1, 1)),
        Rotation = 0,
    }, grid)

    local shade = mk("Frame", {
        Size = UDim2.fromScale(1, 1),
        BackgroundColor3 = Color3.new(0, 0, 0),
        BackgroundTransparency = 0,
        BorderSizePixel = 0,
        ZIndex = 100052,
    }, grid)
    corner(4, shade)

    mk("UIGradient", {
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 1),
            NumberSequenceKeypoint.new(1, 0),
        }),
        Rotation = 90,
    }, shade)

    -- Dotted crosshair on grid
    local crosshairH = mk("Frame", {
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.fromScale(0.5, 0.5),
        BackgroundColor3 = theme.white,
        BackgroundTransparency = 0.4,
        BorderSizePixel = 0,
        ZIndex = 100060,
    }, grid)

    crosshairH.BackgroundColor3 = theme.white
    local dashPattern = "---  ---  ---  ---  ---  ---  ---  ---  ---  ---  ---  ---  ---  ---  ---  ---"
    -- Simulate dashes with alternating frames
    crosshairH.Visible = false

    local crosshairV = mk("Frame", {
        Size = UDim2.new(0, 1, 1, 0),
        Position = UDim2.fromScale(0.5, 0),
        BackgroundColor3 = theme.white,
        BackgroundTransparency = 0.4,
        BorderSizePixel = 0,
        ZIndex = 100060,
    }, grid)
    crosshairV.Visible = false

    -- Crosshair dot in center
    local crosshairDot = mk("Frame", {
        Size = UDim2.fromOffset(5, 5),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.fromScale(0.5, 0.5),
        BackgroundColor3 = theme.white,
        BorderSizePixel = 0,
        ZIndex = 100061,
    }, grid)
    corner(3, crosshairDot)
    stroke(theme.black, 1, 0, crosshairDot)
    crosshairDot.Visible = false

    -- Magnified preview dot near picker
    local preview = mk("Frame", {
        Size = UDim2.fromOffset(18, 18),
        Position = UDim2.new(0, 148, 0, 0),
        BackgroundColor3 = defaultColor,
        Visible = false,
        ZIndex = 100062,
    }, picker)
    corner(9, preview)
    stroke(theme.white, 2, 0, preview)

    -- Hue bar
    local hueBar = mk("Frame", {
        Size = UDim2.fromOffset(144, 14),
        Position = UDim2.fromOffset(0, 69),
        BorderSizePixel = 0,
        ZIndex = 100051,
    }, picker)
    corner(3, hueBar)

    mk("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromHSV(0, 1, 1)),
            ColorSequenceKeypoint.new(0.16, Color3.fromHSV(0.16, 1, 1)),
            ColorSequenceKeypoint.new(0.33, Color3.fromHSV(0.33, 1, 1)),
            ColorSequenceKeypoint.new(0.5, Color3.fromHSV(0.5, 1, 1)),
            ColorSequenceKeypoint.new(0.66, Color3.fromHSV(0.66, 1, 1)),
            ColorSequenceKeypoint.new(0.83, Color3.fromHSV(0.83, 1, 1)),
            ColorSequenceKeypoint.new(1, Color3.fromHSV(1, 1, 1)),
        }),
    }, hueBar)

    -- Hue indicator dot
    local hueDot = mk("Frame", {
        Size = UDim2.fromOffset(8, 16),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0, 0, 0.5, 0),
        BackgroundColor3 = theme.white,
        ZIndex = 100060,
    }, hueBar)
    corner(2, hueDot)
    stroke(theme.black, 1, 0.3, hueDot)

    local draggingGrid, draggingHue = false, false

    local function applyGrid(pos)
        sat = math.clamp((pos.X - grid.AbsolutePosition.X) / grid.AbsoluteSize.X, 0, 1)
        val = 1 - math.clamp((pos.Y - grid.AbsolutePosition.Y) / grid.AbsoluteSize.Y, 0, 1)

        -- Update crosshair position
        local cx = sat
        local cy = 1 - val
        crosshairH.Position = UDim2.new(0, 0, cy, 0)
        crosshairV.Position = UDim2.new(cx, 0, 0, 0)
        crosshairDot.Position = UDim2.new(cx, 0, cy, 0)

        setColor(Color3.fromHSV(hue, sat, val))
    end

    local function applyHue(pos)
        hue = math.clamp((pos.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
        hueDot.Position = UDim2.new(hue, 0, 0.5, 0)
        grid.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
        setColor(Color3.fromHSV(hue, sat, val))
    end

    grid.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingGrid = true
            crosshairH.Visible = true
            crosshairV.Visible = true
            crosshairDot.Visible = true
            preview.Visible = true
            applyGrid(input.Position)
        end
    end)

    grid.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingGrid = false
            crosshairH.Visible = false
            crosshairV.Visible = false
            crosshairDot.Visible = false
            preview.Visible = false
        end
    end)

    hueBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingHue = true
            applyHue(input.Position)
        end
    end)

    hueBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingHue = false
        end
    end)

    self._ui:_trackInput(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        if draggingGrid then
            applyGrid(input.Position)
            preview.BackgroundColor3 = widget.value
        elseif draggingHue then
            applyHue(input.Position)
        end
    end)

    self._ui:_trackInputEnded(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingGrid = false
            draggingHue = false
            crosshairH.Visible = false
            crosshairV.Visible = false
            crosshairDot.Visible = false
            preview.Visible = false
        end
    end)

    swatch.MouseButton1Click:Connect(function()
        picker.Visible = not picker.Visible
        if picker.Visible then
            picker.Position = UDim2.new(1, 10, 0, -10)
            smooth(picker, 0.2, { Position = UDim2.new(1, 10, 0, 0) })
        end
    end)

    hexBox.FocusLost:Connect(function()
        local hex = hexBox.Text:gsub("#", "")
        if #hex ~= 6 then return end
        local r = tonumber(hex:sub(1, 2), 16)
        local g = tonumber(hex:sub(3, 4), 16)
        local b = tonumber(hex:sub(5, 6), 16)
        if r and g and b then
            local color = Color3.fromRGB(r, g, b)
            hue, sat, val = Color3.toHSV(color)
            hueDot.Position = UDim2.new(hue, 0, 0.5, 0)
            grid.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
            setColor(color)
        end
    end)

    function widget:Set(color)
        hue, sat, val = Color3.toHSV(color)
        hueDot.Position = UDim2.new(hue, 0, 0.5, 0)
        grid.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
        setColor(color)
    end
    function widget:Get() return widget.value end

    setColor(defaultColor)
    hueDot.Position = UDim2.new(hue, 0, 0.5, 0)
    grid.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)

    self._ui:_registerWidget(widget)
    return widget
end

function Panel:AddKeybind(label, defaultKey, callback)
    local theme = self._theme
    local row = self:_row(24)
    padding(0, 0, 8, 6, row)

    mk("TextLabel", {
        Text = label,
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextColor3 = theme.text,
        BackgroundTransparency = 1,
        Size = UDim2.new(0.55, 0, 1, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 100013,
    }, row)

    local keyButton = mk("TextButton", {
        Text = "[ " .. (defaultKey and defaultKey.Name or "...") .. " ]",
        Font = Enum.Font.Gotham,
        TextSize = 10,
        TextColor3 = theme.muted,
        BackgroundTransparency = 1,
        AutoButtonColor = false,
        Size = UDim2.new(0.45, -6, 1, 0),
        Position = UDim2.new(0.55, 0, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Right,
        ZIndex = 100013,
    }, row)

    local waiting = false
    local boundKey = defaultKey
    local widget = { type = "keybind", value = defaultKey }

    keyButton.MouseButton1Click:Connect(function()
        waiting = true
        keyButton.Text = "[ ... ]"
        tween(keyButton, 0.1, { TextColor3 = theme.accent })
    end)

    self._ui:_trackInput(function(input, gameProcessed)
        if waiting and input.UserInputType == Enum.UserInputType.Keyboard then
            waiting = false
            if input.KeyCode == Enum.KeyCode.Escape then
                keyButton.Text = "[ ... ]"
                boundKey = nil
                widget.value = nil
                tween(keyButton, 0.1, { TextColor3 = theme.muted })
                if callback then callback(nil) end
                return
            end
            keyButton.Text = "[ " .. input.KeyCode.Name .. " ]"
            tween(keyButton, 0.1, { TextColor3 = theme.muted })
            boundKey = input.KeyCode
            widget.value = input.KeyCode
            if callback then callback(input.KeyCode) end
            return
        end
        if not gameProcessed and boundKey and input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == boundKey then
            if widget._onPress then widget._onPress() end
        end
    end)

    function widget:Set(key)
        boundKey = key
        widget.value = key
        keyButton.Text = key and ("[ " .. key.Name .. " ]") or "[ ... ]"
    end

    function widget:Get()
        return boundKey
    end

    function widget:OnPress(fn)
        widget._onPress = fn
    end

    self._ui:_registerWidget(widget)
    return widget
end

function Panel:AddTextBox(label, default, placeholder, callback)
    local theme = self._theme
    local row = self:_row(28)
    padding(4, 4, 8, 8, row)

    if label and label ~= "" then
        mk("TextLabel", {
            Text = label,
            Font = Enum.Font.Gotham,
            TextSize = 11,
            TextColor3 = theme.text,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 13),
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 100013,
        }, row)
    end

    local box = mk("TextBox", {
        Text = default or "",
        PlaceholderText = placeholder or "",
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextColor3 = theme.text,
        PlaceholderColor3 = theme.dim,
        BackgroundColor3 = theme.rowAlt,
        BackgroundTransparency = 0.4,
        ClearTextOnFocus = false,
        Size = UDim2.new(1, 0, 0, 18),
        Position = (label and label ~= "") and UDim2.new(0, 0, 0, 15) or UDim2.new(0, 0, 0, 5),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 100013,
    }, row)
    corner(4, box)
    padding(0, 0, 6, 6, box)
    stroke(theme.border, 1, 0.2, box)

    box.Focused:Connect(function()
        tween(box, 0.12, { BackgroundTransparency = 0.1 })
        local s = box:FindFirstChildOfClass("UIStroke")
        if s then tween(s, 0.12, { Color = theme.accent }) end
    end)

    box.FocusLost:Connect(function(enter)
        tween(box, 0.12, { BackgroundTransparency = 0.4 })
        local s = box:FindFirstChildOfClass("UIStroke")
        if s then tween(s, 0.12, { Color = theme.border }) end
    end)

    local widget = { type = "textbox", value = default or "" }

    box.FocusLost:Connect(function(enter)
        widget.value = box.Text
        if callback then callback(box.Text, enter) end
    end)

    function widget:Set(text)
        box.Text = text or ""
        widget.value = box.Text
    end

    function widget:Get()
        return box.Text
    end

    self._ui:_registerWidget(widget)
    return widget
end

