function Panel:AddToggle(label, default, callback)
    local theme = self._theme
    local row = self:_row(24)
    padding(0, 0, 8, 6, row)

    mk("TextLabel", {
        Text = label,
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextColor3 = theme.text,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -66, 1, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 100013,
    }, row)

    local bindLabel = mk("TextLabel", {
        Text = "",
        Font = Enum.Font.Code,
        TextSize = 9,
        TextColor3 = theme.dim,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 42, 1, 0),
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(1, -20, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Right,
        ZIndex = 100013,
    }, row)

    local button = mk("TextButton", {
        Text = "",
        Size = UDim2.fromOffset(15, 15),
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, 0, 0.5, 0),
        BackgroundColor3 = theme.rowAlt,
        AutoButtonColor = false,
        ZIndex = 100013,
    }, row)
    corner(8, button)
    stroke(default and theme.accent or theme.borderBright, 1, 0, button)

    local dot = mk("Frame", {
        Size = default and UDim2.fromOffset(9, 9) or UDim2.fromOffset(0, 0),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.fromScale(0.5, 0.5),
        BackgroundColor3 = theme.accent,
        ZIndex = 100014,
    }, button)
    corner(5, dot)

    local ripple = mk("Frame", {
        Size = UDim2.fromOffset(0, 0),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.fromScale(0.5, 0.5),
        BackgroundColor3 = theme.accent,
        BackgroundTransparency = 0.6,
        ZIndex = 100013,
    }, button)
    corner(100, ripple)

    local enabled = default and true or false
    local boundKey
    local waiting = false
    local widget = { type = "toggle", value = enabled }

    local function refresh()
        spring(dot, 0.22, { Size = enabled and UDim2.fromOffset(9, 9) or UDim2.fromOffset(0, 0) })
        local s = button:FindFirstChildOfClass("UIStroke")
        if s then tween(s, 0.15, { Color = enabled and theme.accent or theme.borderBright }) end
    end

    local function flip()
        enabled = not enabled
        widget.value = enabled
        refresh()

        -- Ripple effect
        ripple.Size = UDim2.fromOffset(0, 0)
        ripple.BackgroundTransparency = 0.5
        tween(ripple, 0.4, { Size = UDim2.fromOffset(30, 30), BackgroundTransparency = 1 }, Enum.EasingStyle.Quint)

        if callback then callback(enabled) end
    end

    button.MouseButton1Click:Connect(flip)

    row.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            flip()
        elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
            waiting = true
            bindLabel.Text = "[...]"
            bindLabel.TextColor3 = theme.accent
        end
    end)

    self._ui:_trackInput(function(input, gameProcessed)
        if waiting and input.UserInputType == Enum.UserInputType.Keyboard then
            waiting = false
            if input.KeyCode == Enum.KeyCode.Escape then
                boundKey = nil
                bindLabel.Text = ""
            else
                boundKey = input.KeyCode
                bindLabel.Text = "[" .. input.KeyCode.Name .. "]"
                bindLabel.TextColor3 = theme.dim
            end
            return
        end
        if not gameProcessed and boundKey and input.KeyCode == boundKey and input.UserInputType == Enum.UserInputType.Keyboard then
            flip()
        end
    end)

    function widget:Set(value)
        enabled = value and true or false
        widget.value = enabled
        refresh()
        if callback then callback(enabled) end
    end

    function widget:Get()
        return enabled
    end

    self._ui:_registerWidget(widget)
    return widget
end

function Panel:AddSlider(label, min, max, default, rounding, callback)
    local theme = self._theme
    local row = self:_row(34)
    padding(4, 4, 8, 8, row)

    mk("TextLabel", {
        Text = label,
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextColor3 = theme.text,
        BackgroundTransparency = 1,
        Size = UDim2.new(0.65, 0, 0, 14),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 100013,
    }, row)

    local valueLabel = mk("TextLabel", {
        Text = tostring(default),
        Font = Enum.Font.GothamMedium,
        TextSize = 11,
        TextColor3 = theme.accent,
        BackgroundTransparency = 1,
        Size = UDim2.new(0.35, 0, 0, 14),
        Position = UDim2.new(0.65, 0, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Right,
        ZIndex = 100013,
    }, row)

    local track = mk("Frame", {
        Size = UDim2.new(1, 0, 0, 5),
        Position = UDim2.new(0, 0, 0, 20),
        BackgroundColor3 = theme.rowAlt,
        BorderSizePixel = 0,
        ZIndex = 100013,
    }, row)
    corner(3, track)

    local fill = mk("Frame", {
        Size = UDim2.fromScale((default - min) / (max - min), 1),
        BackgroundColor3 = theme.accent,
        BorderSizePixel = 0,
        ZIndex = 100014,
    }, track)
    corner(3, fill)

    local knob = mk("Frame", {
        Size = UDim2.fromOffset(12, 12),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new((default - min) / (max - min), 0, 0.5, 0),
        BackgroundColor3 = theme.white,
        ZIndex = 100015,
    }, track)
    corner(6, knob)
    stroke(theme.accentDim, 1, 0, knob)

    -- Glow effect on knob
    local glow = mk("Frame", {
        Size = UDim2.fromOffset(20, 20),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.fromScale(0.5, 0.5),
        BackgroundColor3 = theme.accent,
        BackgroundTransparency = 0.7,
        BorderSizePixel = 0,
        ZIndex = 100014,
    }, knob)
    corner(10, glow)

    local widget = { type = "slider", value = default, _min = min, _max = max }

    local function roundValue(v)
        if rounding == nil then return v end
        if rounding == 0 then return math.floor(v + 0.5) end
        local p = 10 ^ rounding
        return math.floor(v * p + 0.5) / p
    end

    local function setValue(v, animate)
        v = math.clamp(v, min, max)
        local alpha = (v - min) / (max - min)
        if animate then
            tween(fill, 0.12, { Size = UDim2.fromScale(alpha, 1) })
            tween(knob, 0.12, { Position = UDim2.new(alpha, 0, 0.5, 0) })
        else
            fill.Size = UDim2.fromScale(alpha, 1)
            knob.Position = UDim2.new(alpha, 0, 0.5, 0)
        end
        local shown = roundValue(v)
        valueLabel.Text = tostring(shown)
        widget.value = shown
        if callback then callback(shown) end
    end

    local dragging = false

    local function getValueFromX(px)
        return min + math.clamp((px - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1) * (max - min)
    end

    -- Better dragging on track AND knob
    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            spring(knob, 0.1, { Size = UDim2.fromOffset(15, 15) })
            setValue(getValueFromX(input.Position.X))
        end
    end)

    knob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            spring(knob, 0.1, { Size = UDim2.fromOffset(15, 15) })
        end
    end)

    self._ui:_trackInput(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            setValue(getValueFromX(input.Position.X))
        end
    end)

    self._ui:_trackInputEnded(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and dragging then
            dragging = false
            spring(knob, 0.15, { Size = UDim2.fromOffset(12, 12) })
        end
    end)

    -- Mouse wheel support
    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseWheel then
            local step = (max - min) / 50
            setValue(widget.value + input.Position.Z * step, true)
        end
    end)

    function widget:Set(v) setValue(v, true) end
    function widget:Get() return widget.value end

    setValue(default)
    self._ui:_registerWidget(widget)
    return widget
end

