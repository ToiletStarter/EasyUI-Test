        Font = Enum.Font.GothamMedium,
        TextSize = 11,
        TextColor3 = theme.accent,
        BackgroundTransparency = 1,
        Size = UDim2.new(0.35, 0, 0, 13),
        Position = UDim2.new(0.65, 0, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Right,
        ZIndex = 100013,
    }, row)

    local track = mk("Frame", {
        Size = UDim2.new(1, 0, 0, 6),
        Position = UDim2.new(0, 0, 0, 17),
        BackgroundColor3 = theme.rowAlt,
        BorderSizePixel = 0,
        ZIndex = 100013,
    }, row)
    corner(3, track)

    local fill = mk("Frame", {
        Size = UDim2.fromScale(math.clamp(initial or 0, 0, 1), 1),
        BackgroundColor3 = theme.accent,
        BorderSizePixel = 0,
        ZIndex = 100014,
    }, track)
    corner(3, fill)

    -- Progress glow
    local glow = mk("Frame", {
        Size = UDim2.fromScale(0, 1),
        AnchorPoint = Vector2.new(0, 0),
        BackgroundColor3 = theme.white,
        BackgroundTransparency = 0.7,
        BorderSizePixel = 0,
        ZIndex = 100015,
    }, fill)
    corner(3, glow)

    local widget = { type = "progress", value = initial or 0 }

    local function setProgress(pct)
        pct = math.clamp(pct, 0, 1)
        widget.value = pct
        tween(fill, 0.2, { Size = UDim2.fromScale(pct, 1) }, Enum.EasingStyle.Quint)
        tween(glow, 0.18, { Size = UDim2.fromScale(pct * 0.3, 1) })
        pctLabel.Text = math.floor(pct * 100 + 0.5) .. "%"
        tween(pctLabel, 0.15, { TextColor3 = pct >= 1 and theme.good or theme.accent })
        if callback then callback(pct) end
    end

    function widget:Set(pct) setProgress(pct) end
    function widget:Get() return widget.value end

    setProgress(initial or 0)
    self._ui:_registerWidget(widget)
    return widget
end

-- ── EasyUI Main ──────────────────────────────────────────
local EasyUI = {}
EasyUI.__index = EasyUI

local activeInstances = {}

function EasyUI.new(options)
    options = options or {}
    local self = setmetatable({}, EasyUI)

    local themeName = options.Theme or "Midnight"
    local theme = Themes[themeName] or Themes.Midnight

    if options.ThemeOverride and type(options.ThemeOverride) == "table" then
        local merged = {}
        for k, v in pairs(theme) do merged[k] = v end
        for k, v in pairs(options.ThemeOverride) do merged[k] = v end
        theme = merged
    end

    if options.Accent then
        theme.accent = options.Accent
        theme.accentDim = Color3.fromRGB(
            math.floor(options.Accent.R * 180),
            math.floor(options.Accent.G * 180),
            math.floor(options.Accent.B * 180)
        )
    end

    self._theme = theme
    self._title = options.Title or "EasyUI"
    self._menuKey = options.MenuKey or Enum.KeyCode.LeftAlt
    self._widgets = {}
    self._panels = {}
    self._inputHandlers = {}
    self._inputEndHandlers = {}
    self._watermarkFn = nil
    self._alive = true
    self._nextX, self._nextY = 16, 52
    self._configOpen = false
    self._cursorEnabled = options.CustomCursor ~= false

    local host = getHost()
    local id = options.Id or ("EasyUI_" .. (tostring(os.clock()):gsub("%.", "_")))
    for _, child in ipairs(host:GetChildren()) do
        if child.Name == id then pcall(function() child:Destroy() end) end
    end

    local gui = mk("ScreenGui", {
        Name = id,
        ResetOnSpawn = false,
        IgnoreGuiInset = true,
        ZIndexBehavior = Enum.ZIndexBehavior.Global,
    }, host)
    pcall(function() gui.DisplayOrder = 2147483647 end)
    pcall(function() if syn and syn.protect_gui then syn.protect_gui(gui) end end)

    self._gui = gui
    self._id = id

    local root = mk("Frame", {
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        Visible = false,
        ZIndex = 100000,
    }, gui)
    self._root = root

    self:_buildWatermark(options.Watermark ~= false)
    self:_buildToasts()
    self:_buildUnloadButton()
    self:_buildCustomCursor()

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if not self._alive then return end
        if input.KeyCode == self._menuKey and not gameProcessed then
            local visible = not root.Visible
            root.Visible = visible
            self:_updateCursor(visible)
            if visible then
                root.Position = UDim2.fromOffset(0, -20)
                smooth(root, 0.3, { Position = UDim2.fromOffset(0, 0) })
                -- Glassmorphism flash
                self:_playGlassFlash()
            else
                self:_updateCursor(false)
            end
        end
        for _, fn in ipairs(self._inputHandlers) do
            fn(input, gameProcessed)
        end
    end)

    UserInputService.InputEnded:Connect(function(input, gameProcessed)
        if not self._alive then return end
        for _, fn in ipairs(self._inputEndHandlers) do
            fn(input, gameProcessed)
        end
    end)

    RunService.RenderStepped:Connect(function(dt)
        if not self._alive then return end

        -- Update custom cursor position
        if self._cursor and self._cursor.Visible then
            local mousePos = UserInputService:GetMouseLocation()
            self._cursor.Position = UDim2.fromOffset(mousePos.X, mousePos.Y)
            -- Subtle idle animation
            self._cursor.Rotation = math.sin(os.clock() * 2) * 3
        end

        -- Watermark
        if self._watermarkFn and self._watermarkLabel then
            local data = self._watermarkFn() or {}
            local parts = { self._title }
            if data.fps then parts[#parts + 1] = tostring(data.fps) .. "fps" end
            for k, v in pairs(data) do
                if k ~= "fps" then
                    parts[#parts + 1] = tostring(k) .. ": " .. tostring(v)
                end
            end
            self._watermarkLabel.Text = table.concat(parts, "  •  ")
        end
    end)

    activeInstances[#activeInstances + 1] = self

    -- Initial glassmorphism load animation
    root.Visible = true
    root.Position = UDim2.fromOffset(0, -20)
    smooth(root, 0.35, { Position = UDim2.fromOffset(0, 0) })
    self:_playGlassFlash()

    return self
end

function EasyUI:_nextPanelPos(width)
    local cam = workspace.CurrentCamera
    local viewport = cam and cam.ViewportSize or Vector2.new(1000, 800)
    if self._nextX + width + 16 > viewport.X then
        self._nextX = 16
        self._nextY = self._nextY + 350
    end
    local x, y = self._nextX, self._nextY
    self._nextX = self._nextX + width + 12
    return x, y
end

function EasyUI:_makeDraggable(handle, frame)
    local dragging = false
    local dragStart
    local startPos

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

function EasyUI:_trackInput(fn) table.insert(self._inputHandlers, fn) end
function EasyUI:_trackInputEnded(fn) table.insert(self._inputEndHandlers, fn) end
function EasyUI:_registerWidget(widget) table.insert(self._widgets, widget) end

function EasyUI:CreatePanel(title, width)
    local p = setmetatable({}, Panel)
    p:_init(self, title, width or 226)
    table.insert(self._panels, p)
    return p
end

function EasyUI:SetMenuKey(key) self._menuKey = key end
function EasyUI:SetVisible(visible)
    self._root.Visible = visible
    self:_updateCursor(visible)
    if visible then self:_playGlassFlash() end
end
function EasyUI:GetVisible() return self._root.Visible end

function EasyUI:GetConfig()
    local out = {}
    for i, w in ipairs(self._widgets) do
        if w.type ~= "button" and w.type ~= "label" then
            out[i] = { type = w.type, value = w.value }
        end
    end
    return out
end

function EasyUI:GetWidgets() return self._widgets end
function EasyUI:GetPanels() return self._panels end

-- ── Watermark ────────────────────────────────────────────
function EasyUI:_buildWatermark(enabled)
    local theme = self._theme

    local wm = mk("Frame", {
        Size = UDim2.new(0, 0, 0, 26),
        AutomaticSize = Enum.AutomaticSize.X,
        Position = UDim2.new(0, 14, 0, 12),
        BackgroundColor3 = theme.panel,
        BackgroundTransparency = 0.08,
        Visible = enabled,
        ZIndex = 180000,
    }, self._gui)
    corner(6, wm)
    stroke(theme.border, 1, 0.3, wm)

    -- Glass effect on watermark
    local wmGlass = mk("Frame", {
        Size = UDim2.fromScale(1, 1),
        BackgroundColor3 = theme.white,
        BackgroundTransparency = 0.93,
        BorderSizePixel = 0,
        ZIndex = 180000,
    }, wm)
    corner(6, wmGlass)

    local dot = mk("Frame", {
        Size = UDim2.fromOffset(8, 8),
        Position = UDim2.new(0, 8, 0.5, -4),
        BackgroundColor3 = theme.accent,
        ZIndex = 180001,
    }, wm)
    corner(4, dot)

    local label = mk("TextLabel", {
        Text = self._title,
        Font = Enum.Font.GothamMedium,
        TextSize = 11,
        TextColor3 = theme.text,
        BackgroundTransparency = 1,
        AutomaticSize = Enum.AutomaticSize.X,
        Size = UDim2.new(0, 0, 1, 0),
        Position = UDim2.new(0, 22, 0, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 180001,
    }, wm)

    mk("UIPadding", { PaddingRight = UDim.new(0, 10) }, wm)

    -- Config gear button on watermark
    local configBtn = mk("TextButton", {
        Text = "⚙",
        Font = Enum.Font.Gotham,
        TextSize = 11,
        TextColor3 = theme.muted,
        BackgroundTransparency = 1,
        AutoButtonColor = false,
        Size = UDim2.fromOffset(20, 26),
        AnchorPoint = Vector2.new(0, 0),
        Position = UDim2.new(0, -24, 0, 0),
        Visible = false,
        ZIndex = 180002,
    }, wm)

    configBtn.MouseButton1Click:Connect(function()
        self:OpenConfig()
    end)
    configBtn.MouseEnter:Connect(function() tween(configBtn, 0.12, { TextColor3 = theme.accent }) end)
    configBtn.MouseLeave:Connect(function() tween(configBtn, 0.12, { TextColor3 = theme.muted }) end)

    -- Show config gear when hovering watermark
    wm.MouseEnter:Connect(function() configBtn.Visible = true end)
    wm.MouseLeave:Connect(function() configBtn.Visible = false end)

    self._watermark = wm
    self._watermarkLabel = label
    self._watermarkDot = dot
    self._configBtn = configBtn

    RunService.RenderStepped:Connect(function()
        if not self._alive or not wm.Visible then return end
        dot.BackgroundColor3 = Color3.fromHSV((os.clock() * 0.12) % 1, 0.6, 1)
    end)
end

function EasyUI:SetWatermarkVisible(visible)
    if self._watermark then self._watermark.Visible = visible end
end

function EasyUI:SetWatermarkStats(fn)
    self._watermarkFn = fn
end

-- ── Unload Button ────────────────────────────────────────
function EasyUI:_buildUnloadButton()
    local theme = self._theme

    local unloadBtn = mk("TextButton", {
        Text = "✕",
        Font = Enum.Font.GothamBold,
        TextSize = 13,
        TextColor3 = theme.muted,
        BackgroundColor3 = theme.panel,
        BackgroundTransparency = 0.08,
        AutoButtonColor = false,
        Size = UDim2.fromOffset(28, 28),
        Position = UDim2.new(1, -42, 0, 14),
        AnchorPoint = Vector2.new(0, 0),
        Visible = false,
        ZIndex = 190000,
    }, self._gui)
    corner(14, unloadBtn)
    stroke(theme.border, 1, 0.3, unloadBtn)

    unloadBtn.MouseButton1Click:Connect(function()
        self:Toast("EasyUI", "Unloading...", 1.5, "warn")
        task.delay(0.6, function() self:Destroy() end)
    end)
    unloadBtn.MouseEnter:Connect(function()
        tween(unloadBtn, 0.12, { TextColor3 = theme.bad, BackgroundTransparency = 0 })
        local s = unloadBtn:FindFirstChildOfClass("UIStroke")
        if s then tween(s, 0.12, { Color = theme.bad }) end
    end)
    unloadBtn.MouseLeave:Connect(function()
        tween(unloadBtn, 0.15, { TextColor3 = theme.muted, BackgroundTransparency = 0.08 })
        local s = unloadBtn:FindFirstChildOfClass("UIStroke")
        if s then tween(s, 0.15, { Color = theme.border }) end
    end)

    self._unloadBtn = unloadBtn

    -- Show/hide with root visibility
    local root = self._root
    local conn
    conn = root:GetPropertyChangedSignal("Visible"):Connect(function()
        if self._unloadBtn then
            self._unloadBtn.Visible = root.Visible
        end
    end)
end

function EasyUI:SetUnloadButtonVisible(visible)
    if self._unloadBtn then self._unloadBtn.Visible = visible end
end

-- ── Custom Cursor ────────────────────────────────────────
function EasyUI:_buildCustomCursor()
    local theme = self._theme

    local cursor = mk("ImageLabel", {
        Size = UDim2.fromOffset(20, 20),
        AnchorPoint = Vector2.new(0, 0),
        BackgroundTransparency = 1,
        Image = "rbxasset://SystemCursors/Arrow",
        ImageColor3 = theme.accent,
        Visible = false,
        ZIndex = 999999,
    }, self._gui)

    local cursorGlow = mk("Frame", {
        Size = UDim2.fromOffset(28, 28),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.fromScale(0.3, 0.3),
        BackgroundColor3 = theme.accent,
        BackgroundTransparency = 0.8,
        BorderSizePixel = 0,
        ZIndex = 999998,
    }, cursor)
    corner(14, cursorGlow)

    self._cursor = cursor
    self._cursorGlow = cursorGlow
end

function EasyUI:_updateCursor(visible)
    if not self._cursorEnabled then return end
    if self._cursor then
        self._cursor.Visible = visible
        if visible then
            -- Hide default cursor
            pcall(function()
                UserInputService.MouseIconEnabled = false
            end)
        else
            pcall(function()
                UserInputService.MouseIconEnabled = true
            end)
        end
    end
end

-- ── Glass Flash Effect ───────────────────────────────────
function EasyUI:_playGlassFlash()
    local theme = self._theme
    local flash = mk("Frame", {
        Size = UDim2.fromScale(1, 1),
        BackgroundColor3 = theme.white,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ZIndex = 999990,
    }, self._gui)

    tween(flash, 0.15, { BackgroundTransparency = 0.85 }, Enum.EasingStyle.Quad)
    task.wait(0.15)
    tween(flash, 0.35, { BackgroundTransparency = 1 }, Enum.EasingStyle.Quint)
    task.delay(0.5, function() pcall(function() flash:Destroy() end) end)
end

-- ── Config Window ────────────────────────────────────────
function EasyUI:OpenConfig()
    if self._configOpen then
        if self._configPanel then
            self._configPanel:SetVisible(false)
        end
        self._configOpen = false
        return
    end

    if self._configPanel then
        self._configPanel:SetVisible(true)
        self._configOpen = true
        return
    end

    local panel = self:CreatePanel("Settings", 240)
    self._configPanel = panel

    panel:AddLabel("UI Configuration")
    panel:AddSeparator("Theme")

    local themes = EasyUI.GetThemes()
    local currentTheme = "Midnight"
    for k, v in pairs(Themes) do
        if v.accent == self._theme.accent and v.panel == self._theme.panel then
            currentTheme = k
            break
        end
    end

    panel:AddDropdown("Theme", themes, currentTheme, function(selected)
        local newTheme = Themes[selected]
        if newTheme then
            for k, v in pairs(newTheme) do
                self._theme[k] = v
            end
            self:Toast("Theme", "Switched to " .. selected, 1.5, "ok")
        end
    end)

    panel:AddSeparator("Appearance")

    local accentPicker = panel:AddColorPicker("Accent Color", self._theme.accent, function(color)
        self._theme.accent = color
        self._theme.accentDim = Color3.fromRGB(
            math.floor(color.R * 160),
            math.floor(color.G * 160),
            math.floor(color.B * 160)
        )
    end)

    panel:AddToggle("Watermark", self._watermark and self._watermark.Visible or true, function(v)
        self:SetWatermarkVisible(v)
    end)

    panel:AddToggle("Custom Cursor", self._cursorEnabled, function(v)
        self._cursorEnabled = v
        if not v and self._cursor then
            self._cursor.Visible = false
            pcall(function() UserInputService.MouseIconEnabled = true end)
        elseif v and self._root.Visible then
            self:_updateCursor(true)
        end
    end)

    panel:AddSeparator("Controls")

    local keybindWidget = panel:AddKeybind("Menu Key", self._menuKey, function(newKey)
        if newKey then
            self._menuKey = newKey
            self:Toast("Keybind", "Menu key set to " .. newKey.Name, 1.5, "ok")
        end
    end)

    panel:AddSeparator("Actions")

    panel:AddButton("Unload UI", function()
        self:Toast("EasyUI", "Unloading...", 1.5, "warn")
        task.delay(0.6, function() self:Destroy() end)
    end, true)

    self._configOpen = true
end

function EasyUI:CloseConfig()
    if self._configPanel then
        self._configPanel:SetVisible(false)
    end
    self._configOpen = false
end

-- ── Toast System ─────────────────────────────────────────
function EasyUI:_buildToasts()
    local holder = mk("Frame", {
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 270, 1, -30),
        Position = UDim2.new(1, -282, 0, 15),
        ZIndex = 200000,
    }, self._gui)

    mk("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 6),
        VerticalAlignment = Enum.VerticalAlignment.Bottom,
        HorizontalAlignment = Enum.HorizontalAlignment.Right,
    }, holder)

    self._toastHolder = holder
    self._toastOrder = 0
end

function EasyUI:Toast(title, msg, duration, kind)
    duration = duration or 3.2
    local theme = self._theme

    local color = (kind == "ok" and theme.good)
        or (kind == "err" and theme.bad)
        or (kind == "warn" and theme.warn)
        or theme.accent

    self._toastOrder += 1

    local toast = mk("Frame", {
        Size = UDim2.new(1, 60, 0, 56),
        Position = UDim2.new(1, 60, 0, 0),
        BackgroundColor3 = theme.panel,
        BackgroundTransparency = 0.05,
        LayoutOrder = self._toastOrder,
        ZIndex = 200000,
        ClipsDescendants = true,
    }, self._toastHolder)
    corner(7, toast)
    stroke(theme.border, 1, 0.2, toast)

    local bar = mk("Frame", {
        Size = UDim2.new(0, 3, 1, -12),
        Position = UDim2.new(0, 6, 0, 6),
        BackgroundColor3 = color,
        BorderSizePixel = 0,
        ZIndex = 200001,
    }, toast)
    corner(2, bar)

    mk("TextLabel", {
        Text = title,
        Font = Enum.Font.GothamMedium,
        TextSize = 11,
        TextColor3 = color,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -24, 0, 15),
        Position = UDim2.new(0, 15, 0, 7),
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 200002,
    }, toast)

    mk("TextLabel", {
        Text = msg,
        Font = Enum.Font.Gotham,
        TextSize = 10,
        TextColor3 = theme.muted,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -24, 0, 26),
        Position = UDim2.new(0, 15, 0, 23),
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top,
        TextWrapped = true,
        ZIndex = 200002,
    }, toast)

    local progress = mk("Frame", {
        Size = UDim2.new(1, 0, 0, 2),
        Position = UDim2.new(0, 0, 1, -2),
        BackgroundColor3 = color,
        BorderSizePixel = 0,
        ZIndex = 200003,
    }, toast)

    spring(toast, 0.35, { Position = UDim2.new(0, 0, 0, 0), Size = UDim2.new(1, 0, 0, 56) })
    tween(progress, duration, { Size = UDim2.new(0, 0, 0, 2) }, Enum.EasingStyle.Linear)

    task.delay(duration, function()
        if not self._alive then return end
        tween(toast, 0.3, { Position = UDim2.new(1, 60, 0, 0), BackgroundTransparency = 1 })
        task.wait(0.35)
        pcall(function() toast:Destroy() end)
    end)
end

-- ── Destroy ──────────────────────────────────────────────
function EasyUI:Destroy()
    self._alive = false
    self:_updateCursor(false)
    for i = #activeInstances, 1, -1 do
        if activeInstances[i] == self then table.remove(activeInstances, i) end
    end
    pcall(function()
        UserInputService.MouseIconEnabled = true
    end)
    pcall(function() self._gui:Destroy() end)
    self._widgets = {}
    self._panels = {}
    self._inputHandlers = {}
    self._inputEndHandlers = {}
end

-- ── Static Methods ───────────────────────────────────────
function EasyUI.SetTheme(name)
    if Themes[name] then
        EasyUI._defaultTheme = name
        return true
    end
    return false
end

function EasyUI.GetThemes()
    local list = {}
    for k in pairs(Themes) do list[#list + 1] = k end
    table.sort(list)
    return list
end

function EasyUI.AddTheme(name, palette)
    if type(name) == "string" and type(palette) == "table" then
        Themes[name] = palette
        return true
    end
    return false
end

return EasyUI
